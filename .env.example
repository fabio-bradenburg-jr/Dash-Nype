NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="YOUR_SUPABASE_PUBLISHABLE_KEY"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Prisma + Supabase Postgres
# DATABASE_URL: use the pooled connection string from Supabase
# DIRECT_URL: use the direct connection string from Supabase
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:[YOUR-PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
REDIS_PASSWORD=""
JWT_SECRET="change-me"
API_PORT="4000"
AI_SERVICE_URL="http://localhost:8000"
PLATFORM_API_URL="http://localhost:4000/api"
PLATFORM_API_TOKEN=""
PLATFORM_TENANT_ID="agency-hub"

# SaaS frontend -> FastAPI backend
NEXT_PUBLIC_PLATFORM_API_URL="http://localhost:8000/api/v1"
# Optional: paste a JWT from POST /api/v1/auth/login to force live frontend requests.
NEXT_PUBLIC_PLATFORM_DEMO_TOKEN=""
# Keep production/staging databases clean. Set true only when intentionally loading demo data locally.
SEED_DEMO_DATA=false
