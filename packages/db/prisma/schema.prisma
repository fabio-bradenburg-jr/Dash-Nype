generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  MASTER
  USER
  VIEWER
  CLIENT
}

enum ClientStatus {
  ACTIVE
  ONBOARDING
  PAUSED
  AT_RISK
  CHURNED
}

enum DashboardKey {
  HOME
  GENERAL
  CLIENT
  EXECUTIVE
  OPERATIONS
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertType {
  LOW_ROI
  PERFORMANCE_DROP
  CLIENT_DISENGAGED
  OPERATIONAL_BOTTLENECK
  LOW_MARGIN
  MANUAL_RISK
}

enum IntegrationProvider {
  META_ADS
  GOOGLE_ADS
  LINKEDIN_ADS
  AGENDOR
  MONDAY
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  SYNCING
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Tenant {
  id                 String                @id @default(uuid())
  name               String
  slug               String                @unique
  themePreference    String                @default("light")
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  users              User[]
  clients            Client[]
  teamMembers        TeamMember[]
  integrations       Integration[]
  dashboardAccesses  DashboardAccess[]
  tasks              Task[]
}

model User {
  id                 String                @id @default(uuid())
  tenantId           String
  email              String
  fullName           String
  passwordHash       String
  role               UserRole
  themePreference    String                @default("light")
  isActive           Boolean               @default(true)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  tenant             Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  clientAccess       UserClientAccess[]
  dashboardAccess    DashboardAccess[]
  sessions           Session[]
  assignedTasks      Task[]                @relation("AssignedTasks")

  @@unique([tenantId, email])
  @@index([tenantId, role])
}

model Session {
  id                 String                @id @default(uuid())
  userId             String
  refreshTokenHash   String
  expiresAt          DateTime
  createdAt          DateTime              @default(now())
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DashboardAccess {
  id                 String                @id @default(uuid())
  tenantId           String
  userId             String
  dashboard          DashboardKey
  canRead            Boolean               @default(true)
  canEdit            Boolean               @default(false)
  tenant             Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dashboard])
}

model Client {
  id                 String                @id @default(uuid())
  tenantId           String
  name               String
  companyName        String
  cnpj               String?
  ownerName          String
  ownerEmail         String?
  goals              Json?
  history            Json?
  status             ClientStatus          @default(ONBOARDING)
  manuallyFlaggedAtRisk Boolean            @default(false)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  tenant             Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  financialMetrics   FinancialMetric[]
  performanceMetrics PerformanceMetric[]
  engagementMetrics  EngagementMetric[]
  operationalMetrics OperationalMetric[]
  qualityMetrics     QualityMetric[]
  healthMetrics      HealthMetric[]
  churnMetrics       ChurnMetric[]
  alerts             Alert[]
  tasks              Task[]
  integrations       Integration[]
  accessUsers        UserClientAccess[]

  @@index([tenantId, status])
}

model UserClientAccess {
  id                 String                @id @default(uuid())
  userId             String
  clientId           String
  canRead            Boolean               @default(true)
  canEdit            Boolean               @default(false)
  user               User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  client             Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
}

model TeamMember {
  id                 String                @id @default(uuid())
  tenantId           String
  fullName           String
  email              String?
  age                Int?
  hireDate           DateTime?
  role               String
  performanceScore   Float                 @default(0)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  tenant             Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tasks              Task[]

  @@index([tenantId, role])
}

model FinancialMetric {
  id                 String                @id @default(uuid())
  clientId           String
  referenceDate      DateTime
  fee                Decimal               @db.Decimal(12, 2)
  ltv                Decimal               @db.Decimal(12, 2)
  investment         Decimal               @db.Decimal(12, 2)
  revenue            Decimal               @db.Decimal(12, 2)
  marginPercent      Float
  createdAt          DateTime              @default(now())
  client             Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, referenceDate])
}

model PerformanceMetric {
  id                 String                @id @default(uuid())
  clientId           String
  referenceDate      DateTime
  roi                Float
  roiWithoutFee      Float
  mmf                Float
  spend              Decimal               @db.Decimal(12, 2)
  conversions        Int
  createdAt          DateTime              @default(now())
  client             Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, referenceDate])
}

model EngagementMetric {
  id                 String                @id @default(uuid())
  clientId           String
  referenceDate      DateTime
  meetingAttendanceRate Float
  crmUsageRate       Float
  stakeholderAlignmentScore Float
  createdAt          DateTime              @default(now())
  client             Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, referenceDate])
}

model OperationalMetric {
  id                 String                @id @default(uuid())
  clientId           String
  referenceDate      DateTime
  tasksOpen          Int
  tasksLate          Int
  averageResolutionHours Float
  productivityIndex  Float
  createdAt          DateTime              @default(now())
  client             Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, referenceDate])
}

model QualityMetric {
  id                 String                @id @default(uuid())
  clientId           String
  referenceDate      DateTime
  csat               Float
  nps                Float
  createdAt          DateTime              @default(now())
  client             Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, referenceDate])
}

model HealthMetric {
  id                 String                @id @default(uuid())
  clientId           String
  referenceDate      DateTime
  score              Float
  band               String
  performanceWeight  Float
  financialWeight    Float
  engagementWeight   Float
  operationalWeight  Float
  qualityWeight      Float
  createdAt          DateTime              @default(now())
  client             Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, referenceDate])
}

model ChurnMetric {
  id                 String                @id @default(uuid())
  clientId           String
  referenceDate      DateTime
  score              Float
  band               String
  reasons            Json
  createdAt          DateTime              @default(now())
  client             Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, referenceDate])
}

model Alert {
  id                 String                @id @default(uuid())
  clientId           String
  type               AlertType
  severity           AlertSeverity
  title              String
  description        String
  isResolved         Boolean               @default(false)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  client             Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, isResolved, severity])
}

model Task {
  id                 String                @id @default(uuid())
  tenantId           String
  clientId           String?
  teamMemberId       String?
  assignedUserId     String?
  title              String
  description        String?
  status             TaskStatus            @default(OPEN)
  priority           TaskPriority          @default(MEDIUM)
  dueDate            DateTime?
  estimatedHours     Float?
  spentHours         Float?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  client             Client?               @relation(fields: [clientId], references: [id], onDelete: SetNull)
  teamMember         TeamMember?           @relation(fields: [teamMemberId], references: [id], onDelete: SetNull)
  tenant             Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedUser       User?                 @relation("AssignedTasks", fields: [assignedUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, priority])
  @@index([clientId, dueDate])
}

model Integration {
  id                 String                @id @default(uuid())
  tenantId           String
  clientId           String?
  provider           IntegrationProvider
  status             IntegrationStatus     @default(DISCONNECTED)
  externalAccountId  String?
  credentials        Json?
  settings           Json?
  lastSyncAt         DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  tenant             Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client             Client?               @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([tenantId, provider, status])
}
